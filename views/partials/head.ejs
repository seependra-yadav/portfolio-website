<!DOCTYPE html>
<html lang="en">
<head>
  <% const safeMetaDescription = (typeof metaDescription !== "undefined" && metaDescription)
    ? metaDescription
    : "Portfolio website of Seependra Singh, full-stack software developer."; %>
  <% const safeCanonicalUrl = (typeof canonicalUrl !== "undefined") ? canonicalUrl : ""; %>
  <% const safeOgImage = (typeof ogImage !== "undefined") ? ogImage : ""; %>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="<%= safeMetaDescription %>" />
  <meta name="robots" content="index, follow" />

  <% if (safeCanonicalUrl) { %>
    <link rel="canonical" href="<%= safeCanonicalUrl %>" />
  <% } %>

  <meta property="og:type" content="website" />
  <meta property="og:title" content="<%= pageTitle %>" />
  <meta property="og:description" content="<%= safeMetaDescription %>" />
  <% if (safeCanonicalUrl) { %>
    <meta property="og:url" content="<%= safeCanonicalUrl %>" />
  <% } %>
  <% if (safeOgImage) { %>
    <meta property="og:image" content="<%= safeOgImage %>" />
  <% } %>

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= pageTitle %>" />
  <meta name="twitter:description" content="<%= safeMetaDescription %>" />
  <% if (safeOgImage) { %>
    <meta name="twitter:image" content="<%= safeOgImage %>" />
  <% } %>

  <title><%= pageTitle %></title>
  <link rel="icon" href="/img/image.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
  <canvas id="particle-canvas" aria-hidden="true"></canvas>
  <div class="main">
    <div class="container">
