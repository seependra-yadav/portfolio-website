<%- include("partials/head", { pageTitle }) %>
<%- include("partials/navbar", { activeRoute }) %>

<section class="section sec-1 active" id="contact">
  <h2>Contact Me</h2>
  <hr />

  <form
    id="contact-form"
    action="<%= formspreeEndpoint || '#' %>"
    method="POST"
    data-enabled="<%= formspreeEndpoint ? 'true' : 'false' %>"
  >
    <label for="name">Name</label>
    <input type="text" id="name" name="name" placeholder="Your Name" required />

    <label for="email">E-mail</label>
    <input type="email" id="email" name="email" placeholder="Your email" required />

    <label for="message">Message</label>
    <textarea id="message" name="message" class="area-text" placeholder="Type here" required></textarea>

    <button id="contact-btn" type="submit" <%= formspreeEndpoint ? '' : 'disabled' %>>
      Send
    </button>
    <p role="status" id="contact-status" hidden></p>

    <p role="alert" id="contact-success" hidden></p>

    <% if (errorMessage) { %>
      <p role="alert" id="contact-error"><%= errorMessage %></p>
    <% } else { %>
      <p role="alert" id="contact-error" hidden></p>
    <% } %>
  </form>
</section>

<script>
  (function () {
    const form = document.getElementById("contact-form");
    if (!form || form.dataset.enabled !== "true") return;

    const successEl = document.getElementById("contact-success");
    const errorEl = document.getElementById("contact-error");
    const statusEl = document.getElementById("contact-status");
    const submitBtn = document.getElementById("contact-btn");
    const defaultBtnText = submitBtn.textContent.trim();

    form.addEventListener("submit", async function (event) {
      event.preventDefault();

      successEl.hidden = true;
      errorEl.hidden = true;
      statusEl.hidden = false;
      statusEl.textContent = "Sending your message...";
      form.setAttribute("aria-busy", "true");
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending...";

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" }
        });

        if (!response.ok) {
          throw new Error("Formspree submission failed");
        }

        form.reset();
        successEl.textContent = "Thank you for reaching out. I will get back to you shortly.";
        successEl.hidden = false;
        statusEl.hidden = true;
      } catch (error) {
        errorEl.textContent = "Unable to send message right now. Please try again later.";
        errorEl.hidden = false;
        statusEl.hidden = true;
      } finally {
        form.removeAttribute("aria-busy");
        submitBtn.disabled = false;
        submitBtn.textContent = defaultBtnText;
      }
    });
  })();
</script>

<%- include("partials/footer") %>
